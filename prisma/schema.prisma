generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contacts")
}

model User {
  id               String   @id @default(uuid())
  name             String
  email            String   @unique
  password         String?
  photo            String?
  avatarPublicId   String?
  avatarUrl        String?
  isGoogleSignedIn Boolean  @default(false)
  role             Role     @default(USER)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  friendsRequested Friendship[]      @relation("Requesters")
  friendsReceived  Friendship[]      @relation("Receivers")
  chats            Chat[]            @relation("UserChats")
  sentMessages     Message[]         @relation("UserMessages")
  notifications    Notification[]
  createdGroups    Group[]           @relation("GroupAdmin")
  groupMemberships GroupMembership[]
}

enum Role {
  USER
  ADMIN
}

model Group {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  adminId       String
  admin         User              @relation("GroupAdmin", fields: [adminId], references: [id])
  groupType     GroupType
  memberships   GroupMembership[]
  projectGroup  ProjectGroup?
  rideGroup     RideGroup?
  roommateGroup RoommateGroup?
}

enum GroupType {
  PROJECT
  RIDE
  ROOMMATE
}

model ProjectGroup {
  groupId     String  @id
  title       String
  description String?
  maxSize     Int
  goal        String?

  group       Group             @relation(fields: [groupId], references: [id])
  memberships GroupMembership[]
}

model RideGroup {
  groupId        String  @id
  source         String
  destination    String
  totalPrice     Float
  maxSize        Int
  carName        String?
  driverName     String?
  prizePerPerson Float

  group       Group             @relation(fields: [groupId], references: [id])
  memberships GroupMembership[]
}

model RoommateGroup {
  groupId       String  @id
  location      String
  maxSize       Int
  contactNumber String?

  group       Group             @relation(fields: [groupId], references: [id])
  memberships GroupMembership[]
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String
  requester   User             @relation("Requesters", fields: [requesterId], references: [id])
  receiverId  String
  receiver    User             @relation("Receivers", fields: [receiverId], references: [id])
  status      FriendshipStatus @default(PENDING)

  createdAt DateTime @default(now())

  @@unique([requesterId, receiverId])
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Chat {
  id        String    @id @default(uuid())
  isGroup   Boolean   @default(false)
  name      String?
  users     User[]    @relation("UserChats")
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id        String     @id @default(uuid())
  content   String?
  mediaUrl  String?
  mediaType MediaType?
  senderId  String
  sender    User       @relation("UserMessages", fields: [senderId], references: [id])
  chatId    String
  chat      Chat       @relation(fields: [chatId], references: [id])
  createdAt DateTime   @default(now())
}

enum MediaType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

model Notification {
  id        String   @id @default(uuid())
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model GroupMembership {
  userId          String
  groupId         String
  user            User           @relation(fields: [userId], references: [id])
  group           Group          @relation(fields: [groupId], references: [id])
  projectGroupId  String? // Nullable for non-project groups
  projectGroup    ProjectGroup?  @relation(fields: [projectGroupId], references: [groupId])
  rideGroupId     String? // Nullable for non-ride groups
  rideGroup       RideGroup?     @relation(fields: [rideGroupId], references: [groupId])
  roommateGroupId String? // Nullable for non-roommate groups
  roommateGroup   RoommateGroup? @relation(fields: [roommateGroupId], references: [groupId])
  createdAt       DateTime       @default(now())

  @@id([userId, groupId])
}
