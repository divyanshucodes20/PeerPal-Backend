generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contacts")
}

model User {
  id               String   @id @default(uuid())
  name             String
  email            String   @unique
  password         String
  photo            String?
  avatarPublicId   String?
  avatarUrl        String?
  isGoogleSignedIn Boolean  @default(false)
  role             Role     @default(USER)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  learningRequests LearningRequest[]
  roommateRequests RoommateRequest[]
  rideRequests     RideRequest[]
  projects         Project[]          @relation("ProjectMembers")
  ledProjects      Project[]          @relation("ProjectLeader")
  chats            Chat[]             @relation("UserChats")
  createdChats     Chat[]             @relation("ChatCreator")
  messages         Message[]
}

enum Role {
  USER
  ADMIN
}

model LearningRequest {
  id            String   @id @default(uuid())
  title         String
  description   String
  creatorId     String
  creator       User     @relation(fields: [creatorId], references: [id])
  maxSize       Int
  contactNumber String?
  project       Project? // No fields/references here
  createdAt     DateTime @default(now())
}

model Project {
  id                String   @id @default(uuid())
  name              String
  description       String?
  leaderId          String
  leader            User     @relation("ProjectLeader", fields: [leaderId], references: [id])
  members           User[]   @relation("ProjectMembers")
  learningRequestId String?  @unique // Add `@unique` to enforce one-to-one relationship
  learningRequest   LearningRequest? @relation(fields: [learningRequestId], references: [id], onDelete: Cascade)
  goals             Goal[]
  createdAt         DateTime @default(now())
}



model RoommateRequest {
  id            String   @id @default(uuid())
  pgName        String
  description   String
  creatorId     String
  creator       User     @relation(fields: [creatorId], references: [id])
  location      String
  contactNumber String?
  createdAt     DateTime @default(now())
}

model RideRequest {
  id            String   @id @default(uuid())
  source        String
  destination   String
  carName       String
  pricePerPerson Float
  creatorId     String
  creator       User     @relation(fields: [creatorId], references: [id])
  contactNumber String?
  createdAt     DateTime @default(now())
}

model Goal {
  id         String  @id @default(uuid())
  content    String
  completed  Boolean @default(false)
  projectId  String
  project    Project @relation(fields: [projectId], references: [id])
}

model Chat {
  id          String   @id @default(uuid())
  name        String
  groupChat   Boolean  @default(false)
  creatorId   String?
  creator     User?    @relation("ChatCreator", fields: [creatorId], references: [id])
  members     User[]   @relation("UserChats")
  messages    Message[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Message {
  id          String     @id @default(uuid())
  content     String?
  attachments Attachment[]
  senderId    String
  sender      User       @relation(fields: [senderId], references: [id])
  chatId      String
  chat        Chat       @relation(fields: [chatId], references: [id])
  createdAt   DateTime   @default(now())
}

model Attachment {
  id        String @id @default(uuid())
  publicId  String
  url       String
  messageId String
  message   Message @relation(fields: [messageId], references: [id])
}
